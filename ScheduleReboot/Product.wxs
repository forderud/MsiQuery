<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
    <Package Name="ScheduleReboot" Language="1033" Version="1.0.0.0" Manufacturer="MsiQuery project" UpgradeCode="0d2456ba-6b7e-46aa-bec2-428f174081cf">
        <!-- Disable downgrades, prevent side-by-side installations of same version -->
        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." AllowSameVersionUpgrades="yes" />
        <!-- Embed binaries inside MSI instead of separate CAB files -->
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="ScheduleReboot" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
        </Feature>
    </Package>

    <Fragment>
        <!-- Visual C++ 2015-2022 Redistributable (x64) version check. Returns 0.0.0.0 if not found (https://wixtoolset.org/docs/schema/util/productsearch/) -->
        <util:ProductSearch Id="VCREDIST_x64_UC_CHECK"
            UpgradeCode="36F68A90-239C-34DF-B58C-64B30153CE35"
            Result="version"
            Variable="VCREDIST_x64_VER1" />

        <util:FileSearch Id="VCREDIST_x64_FILE_CHECK"
            Path="vcruntime140.dll"
            Result="version"
            Variable="VCREDIST_x64_VER2" />

        <PackageGroup Id="VisualCppRuntime">
            <ExePackage Name="vc_redist.x64.exe" DisplayName="Microsoft Visual C++ 2015-2022 Redistributable (x64) - 14.0.24215" Cache="no"
                        Compressed="no" PerMachine="yes" Permanent="yes" Vital="yes" DetectCondition="VCREDIST_x64_VER1 &gt;= v14.32.31332.0"
                        DownloadUrl="https://download.microsoft.com/download/6/A/A/6AA4EDFF-645B-48C5-81CC-ED5963AEAD48/vc_redist.x64.exe"
                        InstallCommand="/install /quiet /norestart" RepairCommand="/repair /quiet /norestart" UninstallCommand="/uninstall /quiet /norestart" >
            <!-- Must be generated with the following command: "heat payload vc_redist.x64.exe -out vc_redist.x64.wxs" -->
            <RemotePayload CertificatePublicKey="371DD003A37769487A2A89A5A9DDB3026451B906" CertificateThumbprint="98ED99A67886D020C564923B7DF25E9AC019DF26"
                            Description="Microsoft Visual C++ 2015-2022 Redistributable (x64) - 14.0.24215" Hash="10B1683EA3FF5F36F225769244BF7E7813D54AD0"
                            ProductName="Microsoft Visual C++ 2015-2022 Redistributable (x64) - 14.0.24215" Size="15301888" Version="14.0.24215.1" />
            </ExePackage>
        </PackageGroup>

        <!-- Precondition check (https://wixtoolset.org/docs/schema/bal/condition/) -->
        <bal:Condition Condition="VCREDIST_x64_VER1 &gt;= v14.32.31332.0" Message="Microsoft Visual C++ 2015-2022 (x64) Redistributable missing" />

        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="ScheduleReboot" />
        </StandardDirectory>
    </Fragment>

    <Fragment>
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="README.txt">
                <File Id="README.txt" KeyPath="yes" Source="README.txt" />
            </Component>
        </ComponentGroup>
    </Fragment>
</Wix>
